---
import IMGCol from "../components/IMGCol.astro";
import Default from "../layouts/Default.astro";
import GranBoton from "../components/GranBoton.astro";
---

<Default title="PingPongASO" header={false}>
    <div id="hellospace"></div>
    <div id="ball"></div>
    <div id="hello"></div>
    <div id="moTitle">
        <p>Crea tu propia pala para jugar en el torneo.</p>
        <div>
            <GranBoton
                id="biGo"
                texto="Quiero Participar"
                url="https://aedm.notion.site/34076f0f98e280f9882dcb91ba8c927d?pvs=105"
            />
        </div>
    </div>
    <IMGCol
        src="/aso-content/pingpongaso/superbola.png"
        alt="PingPongPala"
        wait2appear={4}
    >
        El PingPongASO es un torneo de ping-pong en el que el requisito para
        participar es diseñar y fabricar tu propia pala.
    </IMGCol>

    <h3>Requisitos</h3>
    <ol style="list-style-type: decimal; text-indent: 20px; font-size: 18px;">
        <li>Ser parte de la ESD.</li>
        <li>Haberte fabricado tú tu propia pala.</li>
    </ol>
    <h1 style="text-align: center; margin: 10px 0;">Caza de Referencias</h1>

    <section class="skipMargins">
        <section class="pinScroll">
            <img src="/aso-content/pingpongaso/pin/1.jpg" alt="" />
            <img src="/aso-content/pingpongaso/pin/2.jpg" alt="" />
            <img src="/aso-content/pingpongaso/pin/3.jpg" alt="" />
            <img src="/aso-content/pingpongaso/pin/4.jpg" alt="" />
            <img src="/aso-content/pingpongaso/pin/5.jpg" alt="" />
            <img src="/aso-content/pingpongaso/pin/6.jpg" alt="" />
        </section>
    </section>
    <p style="font-size: 18px">
        Únete a nuestro panel de referencias colaborativo para inspirarte en tu
        propia pala. Es un <a href="https://pin.it/2noJ6xLKs" target="_blank">
            tablero de Pinterest</a
        > en el que <b>todos</b>

        <i style="color: var(--gris4); font-style: normal">
            (los de la ESD) <b>pueden colaborar añadiendo referencias.</b>
        </i>
    </p>
    <GranBoton
        texto="Colaborar"
        url="https://verificaso.aedm.org.es/claim/c17381e7-d231-4ffa-9d1e-636384b76265"
    />
    <hr />
    <i
        >Actividad no asegurada, estamos tanteando si participarás. Necesitas o
        bien un correo @educa.madrid.org con acceso a emails externos
        habilitados o un correo @esdmadrid.es y ser parte de la ESD actualmente.</i
    >
    <p style="color: var(--gris4)">
        La imágen de la instalación es una reinterpretación de la obra "<a
            href="https://www.artandsciencejournal.com/post/28133820990/richard-fauguet-untitled-2000-2005-in-this"
            target="_blank">Richard Fauguet - Untitled 2000-2005</a
        >". aedm/aadm es una organización sin ánimo de lucro sin relación con la
        obra original. La obra original es propiedad de Richard Fauguet.
    </p>
</Default>

<style>
    .pinScroll {
        display: flex;
        overflow-x: auto;
        width: calc(100% - 10px);
        gap: 10px;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
        height: 400px;
        position: relative;
        padding-left: 10px;
    }
    #biGo {
        max-width: 800px;
    }
    #moTitle {
        /*position: absolute;
        top: 0;
        left: 0;
        right: 0;
        display: flex;*/
        justify-content: center;
        align-items: center;
        flex-direction: column;
        padding: 40px;
        width: 100%;
        transition: opacity 1s ease;
        opacity: 0;
        text-align: center;

        p {
            font-size: 30px;
            text-transform: uppercase;
        }
    }
    #hello {
        position: absolute;
        width: 100vw;
        aspect-ratio: 16 / 9;
        background: url("/img/pingponghola.png");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        left: 0;
        right: 0;
        top: 0;
        mix-blend-mode: darken;
        z-index: -100000;
        transition: aspect-ratio 1s ease;
    }
    #hellospace {
        overflow: hidden;
        width: 100%;
        margin-top: 0;
    }
    @keyframes shake {
        0%,
        100% {
            transform: translateX(0) scale(1);
        }
        25% {
            transform: translateX(-2px) scale(1);
        }
        50% {
            transform: translateX(2px) scale(1);
        }
        75% {
            transform: translateX(-2px) scale(1);
        }
    }

    #ball {
        position: fixed;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        /*background: #a03e95;*/
        background: #22c55e;
        display: none;
        z-index: 1000;
        cursor: grab;
        user-select: none !important;
        /*mix-blend-mode: difference; no me convence esto*/
        transition: scale 0.5s ease;
    }
    #ball.hovering-quiet {
        animation: shake 0.3s infinite;
        cursor: grab;
        user-select: none !important;
    }
    #ball.dragging {
        cursor: grabbing;
        user-select: none;
        transition: scale 0.5s ease;
        transform: scale(1.2);
        z-index: 10000000001;
        animation: none;
        user-select: none !important;
    }

    @media (max-width: 850px) {
        #hello {
            background: url("/img/pingpongphone.png");
            aspect-ratio: 1 / 1;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            transition: all 1s ease;
        }
        #hellospace {
            margin-bottom: 20px;
        }
        #ball {
            width: 60px;
            height: 60px;
        }
        .pinScroll {
            height: 280px;
        }
    }
</style>

<script>
    function adjustHellospace() {
        let hello = document.getElementById("hello");
        let hellospace = document.getElementById("hellospace");
        let moTitle = document.getElementById("moTitle");

        if (hello && hellospace && moTitle) {
            let helloHeight = Number(hello?.offsetHeight);
            console.log(helloHeight);
            let hellospaceHeight = helloHeight - 200;
            hellospace.style.height = hellospaceHeight + "px";
        }
    }

    // Pelota de pingpong (escrito por ia)
    let ball = {
        x: window.innerWidth / 2,
        y: window.innerHeight / 2,
        vx: 4,
        vy: 4,
        radius: 15,
        visible: false,
        isDragging: false,
        dragOffsetX: 0,
        dragOffsetY: 0,
        prevX: window.innerWidth / 2,
        prevY: window.innerHeight / 2,
    };

    function drawBall() {
        const ballElement = document.getElementById("ball");
        if (ballElement) {
            ballElement.style.left = ball.x - ball.radius + "px";
            ballElement.style.top = ball.y - ball.radius + "px";
        }
    }

    function updateBall() {
        if (ball.isDragging) return;

        ball.x += ball.vx;
        ball.y += ball.vy;

        // Aplicar fricción (desaceleración)
        ball.vx *= 0.98;
        ball.vy *= 0.98;

        // Rebotar en los bordes
        if (
            ball.x - ball.radius <= 0 ||
            ball.x + ball.radius >= window.innerWidth
        ) {
            ball.vx = -ball.vx;
            ball.x = Math.max(
                ball.radius,
                Math.min(window.innerWidth - ball.radius, ball.x),
            );
        }

        if (
            ball.y - ball.radius <= 0 ||
            ball.y + ball.radius >= window.innerHeight
        ) {
            ball.vy = -ball.vy;
            ball.y = Math.max(
                ball.radius,
                Math.min(window.innerHeight - ball.radius, ball.y),
            );
        }

        drawBall();
    }

    function startBallAnimation() {
        const ballElement = document.getElementById("ball");
        if (ballElement) {
            ball.visible = true;
            ballElement.style.display = "block";
        }

        setInterval(updateBall, 20);
    }

    // Detectar hover y quiet state
    let hoveringBall = false;

    document.addEventListener("mousemove", (e) => {
        const ballElement = document.getElementById("ball");
        if (!ballElement || ballElement.style.display === "none") return;

        const rect = ballElement.getBoundingClientRect();
        const distance = Math.sqrt(
            (e.clientX - (rect.left + rect.width / 2)) ** 2 +
                (e.clientY - (rect.top + rect.height / 2)) ** 2,
        );

        const isHovering = distance <= ball.radius * 2;
        const isQuiet = Math.abs(ball.vx) < 0.5 && Math.abs(ball.vy) < 0.5;

        if (isHovering && isQuiet && !ball.isDragging) {
            if (!hoveringBall) {
                hoveringBall = true;
                ballElement.classList.add("hovering-quiet");
            }
        } else {
            if (hoveringBall) {
                hoveringBall = false;
                ballElement.classList.remove("hovering-quiet");
            }
        }
    });

    // Eventos de arrastre
    document.addEventListener("mousedown", (e) => {
        const ballElement = document.getElementById("ball");
        if (!ballElement || ballElement.style.display === "none") return;

        const rect = ballElement.getBoundingClientRect();
        const distance = Math.sqrt(
            (e.clientX - (rect.left + rect.width / 2)) ** 2 +
                (e.clientY - (rect.top + rect.height / 2)) ** 2,
        );

        if (distance <= ball.radius) {
            ball.isDragging = true;
            ball.dragOffsetX = e.clientX - (rect.left + rect.width / 2);
            ball.dragOffsetY = e.clientY - (rect.top + rect.height / 2);
            ballElement.classList.add("dragging");
            ballElement.classList.remove("hovering-quiet");
            hoveringBall = false;
        }
    });

    document.addEventListener(
        "mousemove",
        (e) => {
            if (ball.isDragging) {
                ball.prevX = ball.x;
                ball.prevY = ball.y;
                ball.x = e.clientX - ball.dragOffsetX;
                ball.y = e.clientY - ball.dragOffsetY;
                drawBall();
            }
        },
        true,
    );

    document.addEventListener("mouseup", (e) => {
        if (ball.isDragging) {
            ball.isDragging = false;
            const ballElement = document.getElementById("ball");
            if (ballElement) {
                ballElement.classList.remove("dragging");
            }

            // Calcular velocidad basada en el movimiento anterior
            ball.vx = (ball.x - ball.prevX) * 0.5;
            ball.vy = (ball.y - ball.prevY) * 0.5;
        }
    });

    function moveHello6s() {
        // a partir de aquí que acaba lo relacionado con la pelota, ya me podeis crucuficar si algo falla
        let hello = document.getElementById("hello");
        let moTitle = document.getElementById("moTitle");
        if (hello && moTitle) {
            setTimeout(() => {
                // hello.style.top = "-100px";
                if (window.innerWidth < 768) {
                    hello.style.top = "100px";
                }
                hello.style.aspectRatio = "21 / 9";
                // esperar transición
                setTimeout(() => {
                    adjustHellospace();
                    moTitle.style.opacity = "1";
                    startBallAnimation();
                }, 1100);
            }, 6000);
        }
    }

    window.addEventListener("load", adjustHellospace);
    window.addEventListener("resize", adjustHellospace);
    window.addEventListener("load", moveHello6s);
    window.addEventListener("resize", moveHello6s);

    function handleImageLoad() {
        adjustHellospace();
        moveHello6s();
    }

    const hello = document.getElementById("hello");
    if (hello) {
        if (hello.complete) {
            handleImageLoad();
        } else {
            hello.addEventListener("load", handleImageLoad);
        }
    }
</script>
