---
import Default from "../layouts/Default.astro";
import Boton from "../components/Boton.astro";
---

<Default title="404" header={false}>
    <!-- Contenedor del error 404 (se oculta si la URL es /id/{pageId}) -->
    <div id="error-404">
        <h1>404</h1>
        <p>Lo sentimos, la página que buscas no se ha encontrado.</p>
        <Boton texto="Ir a la página de inicio" url="/" />
    </div>

    <!-- Contenedor de la página de Notion (oculto por defecto) -->
    <div id="notion-container" style="display:none;">
        <div id="notion-loading">
            <img id="loading-spinner" src="/aedm.svg" alt="Cargando..." />
        </div>
        <div id="notion-content" style="display:none;"></div>
        <div id="notion-error" style="display:
none;">
            <h1>Error</h1>
            <p>No hemos podido cargar la página solicitada.</p>
            <a href="/">Ir a la página de inicio</a>
        </div>
    </div>
</Default>

<script>
    const path = window.location.pathname;
    const match = path.match(/^\/id\/([^/]+)\/?$/);

    if (match) {
        const pageId = match[1];

        // Ocultar 404 y mostrar contenedor Notion
        document.getElementById("error-404").style.display = "none";
        document.getElementById("notion-container").style.display = "block";

        // Actualizar el título de la página mientras carga
        document.title = "Cargando... | aedm";

        async function loadPage(url) {
            const res = await fetch(url);
            if (!res.ok) throw new Error(String(res.status));
            const data = await res.json();
            // La API puede devolver { error: "..." } con status 200
            if (data.error) throw new Error(data.error);
            return data;
        }

        async function renderPage() {
            let page = null;

            try {
                page = await loadPage(
                    `https://api.aedm.org.es/id/${pageId}.json`,
                );
            } catch {
                // Intentar fallback local
                try {
                    page = await loadPage(`/failback/${pageId}.json`);
                } catch {
                    document.getElementById("notion-loading").style.display =
                        "none";
                    document.getElementById("notion-error").style.display =
                        "block";
                    document.title = "Error | aedm";
                    return;
                }
            }

            document.title = (page.current_page_title || "") + " | aedm";

            const tags = Array.isArray(page.tags) ? page.tags : [];

            let html = `<article class="notion-page">`;
            html += `<header><h1>${escapeHtml(page.current_page_title || "")}</h1>`;

            if (tags.length > 0) {
                html += `<div class="notion-tags">`;
                tags.forEach((t) => {
                    html += `<span class="notion-tag">${escapeHtml(t)}</span>`;
                });
                html += `</div>`;
            }

            html += `</header><section class="notion-content">`;
            html += renderBlocks(page.blocks || []);
            html += `</section></article>`;

            const contentEl = document.getElementById("notion-content");
            contentEl.innerHTML = html;
            document.getElementById("notion-loading").style.display = "none";
            contentEl.style.display = "block";
        }

        function escapeHtml(str) {
            return String(str)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;");
        }

        /**
         * renderRichText — converts an array of rich text items to HTML spans/links.
         * Handles bold, italic, underline, strikethrough, code, href.
         */
        function renderRichText(richTexts) {
            if (!Array.isArray(richTexts) || richTexts.length === 0)
                return "&nbsp;";
            return richTexts
                .map((rt) => {
                    let text = escapeHtml(rt.plain_text || "");
                    const ann = rt.annotations || {};
                    if (ann.bold) text = `<strong>${text}</strong>`;
                    if (ann.italic) text = `<em>${text}</em>`;
                    if (ann.strikethrough) text = `<s>${text}</s>`;
                    if (ann.underline) text = `<u>${text}</u>`;
                    if (ann.code) text = `<code>${text}</code>`;
                    if (rt.href) {
                        const rel = `target="_blank" rel="noreferrer"`;
                        text = `<a href="${escapeHtml(rt.href)}" ${rel}>${text}</a>`;
                    }
                    return text;
                })
                .join("");
        }

        function getPlainText(richTexts) {
            if (!Array.isArray(richTexts)) return "";
            return richTexts.map((r) => r.plain_text || "").join("");
        }

        /**
         * renderBlocks — uses the FLAT API structure where rich_text, url,
         * caption, title, checked live directly on the block object
         * (block.rich_text, block.url, etc.), NOT nested inside block[block.type].
         *
         * This mirrors the NotionBlocks.astro server component behavior.
         */
        function renderBlocks(blocks) {
            let html = "";
            let i = 0;

            while (i < blocks.length) {
                const block = blocks[i];
                const type = block.type;

                // --- Bulleted lists: group consecutive items ---
                if (type === "bulleted_list_item") {
                    html += `<ul class="notion-block bulleted-list">`;
                    while (
                        i < blocks.length &&
                        blocks[i].type === "bulleted_list_item"
                    ) {
                        html += `<li class="notion-block bulleted-list-item">${renderRichText(blocks[i].rich_text)}</li>`;
                        i++;
                    }
                    html += `</ul>`;
                    continue;
                }

                // --- Numbered lists: group consecutive items ---
                if (type === "numbered_list_item") {
                    html += `<ol class="notion-block numbered-list">`;
                    while (
                        i < blocks.length &&
                        blocks[i].type === "numbered_list_item"
                    ) {
                        html += `<li class="notion-block numbered-list-item">${renderRichText(blocks[i].rich_text)}</li>`;
                        i++;
                    }
                    html += `</ol>`;
                    continue;
                }

                switch (type) {
                    case "paragraph": {
                        html += `<p class="notion-block paragraph">${renderRichText(block.rich_text)}</p>`;
                        break;
                    }

                    case "heading_1": {
                        html += `<h1 class="notion-block heading-1">${renderRichText(block.rich_text)}</h1>`;
                        break;
                    }

                    case "heading_2": {
                        // If there is exactly one rich text item with an href,
                        // render it as a GranBoton-style CTA (matching server component).
                        const rt2 = block.rich_text || [];
                        if (rt2.length === 1 && rt2[0].href) {
                            const label = escapeHtml(
                                rt2[0].plain_text || rt2[0].href,
                            );
                            const href = escapeHtml(rt2[0].href);
                            html += `<div class="notion-block heading-2 gran-boton-wrap">
                                <a class="gran-boton" href="${href}" target="_blank" rel="noreferrer">
                                    <div class="verde" style="flex-direction:row-reverse;justify-content:space-between;">
                                        <span class="material-symbols-outlined">arrow_outward</span>
                                        <p>${label}</p>
                                    </div>
                                </a>
                            </div>`;
                        } else {
                            html += `<h2 class="notion-block heading-2">${renderRichText(block.rich_text)}</h2>`;
                        }
                        break;
                    }

                    case "heading_3": {
                        html += `<h3 class="notion-block heading-3">${renderRichText(block.rich_text)}</h3>`;
                        break;
                    }

                    case "quote": {
                        html += `<blockquote class="notion-block quote">${renderRichText(block.rich_text)}</blockquote>`;
                        break;
                    }

                    case "to_do": {
                        const checked = block.checked ? "checked" : "";
                        html += `<label class="notion-block todo-item">
                            <input type="checkbox" disabled ${checked} />
                            <span>${renderRichText(block.rich_text)}</span>
                        </label>`;
                        break;
                    }

                    case "code": {
                        const codeText = escapeHtml(
                            getPlainText(block.rich_text),
                        );
                        html += `<pre class="notion-block code-block"><code data-language="${escapeHtml(block.language || "")}">${codeText}</code></pre>`;
                        break;
                    }

                    case "divider": {
                        html += `<hr class="notion-block divider" />`;
                        break;
                    }

                    case "image": {
                        // Flat API: url lives directly on block.url
                        const src = escapeHtml(block.url || "");
                        const captionHtml = renderRichText(block.caption || []);
                        const captionPlain = escapeHtml(
                            getPlainText(block.caption || []),
                        );
                        const hasCaption =
                            Array.isArray(block.caption) &&
                            block.caption.length > 0;
                        html += `<figure class="notion-block image">
                            <img src="${src}" alt="${captionPlain}" style="max-width:100%;" loading="lazy" onerror="this.style.display='none'" />
                            ${hasCaption ? `<figcaption>${captionHtml}</figcaption>` : ""}
                        </figure>`;
                        break;
                    }

                    case "bookmark": {
                        // Flat API: url lives directly on block.url
                        const bUrl = escapeHtml(block.url || "");
                        html += `<div class="notion-block bookmark">
                            <a href="${bUrl}" target="_blank" rel="noopener noreferrer">${bUrl}</a>
                        </div>`;
                        break;
                    }

                    case "embed": {
                        // Flat API: url lives directly on block.url
                        const eUrl = escapeHtml(block.url || "");
                        html += `<div class="notion-block embed">
                            <iframe src="${eUrl}" style="width:100%;min-height:200px;border:0;" loading="lazy" allowfullscreen></iframe>
                        </div>`;
                        break;
                    }

                    case "child_page": {
                        // Flat API: title lives directly on block.title
                        const cpTitle = escapeHtml(block.title || "");
                        const cpId = escapeHtml(block.id || "");
                        html += `<div class="notion-block child-page">
                            <a href="/id/${cpId}" class="child-page-link">
                                <span class="material-symbols-outlined">arrow_forward</span>
                                ${cpTitle}
                            </a>
                        </div>`;
                        break;
                    }

                    default:
                        break;
                }

                i++;
            }

            return html;
        }

        renderPage();
    }
</script>

<style is:global>
    #notion-loading {
        display: flex;
        justify-content: center;
        padding: 4rem 0;
    }

    #loading-spinner {
        height: 80px;
        width: auto;
    }

    /* ── Notion page wrapper ── */
    #notion-content .notion-page {
        width: 100%;
    }

    #notion-content .notion-page header {
        margin-bottom: 16px;
    }

    #notion-content .notion-tags {
        margin-top: 8px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    #notion-content .notion-tag {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 999px;
        background: #f1f1f1;
        font-size: 12px;
    }

    #notion-content .notion-content {
        margin-top: 16px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    /* ── Block types ── */
    #notion-content .notion-block.paragraph {
        margin: 0.25em 0;
    }

    #notion-content .notion-block.heading-1 {
        margin: 1em 0 0.5em;
    }

    #notion-content .notion-block.heading-2 {
        margin: 0.8em 0 0.4em;
    }

    #notion-content .notion-block.heading-3 {
        margin: 0.6em 0 0.3em;
    }

    #notion-content .notion-block.quote {
        border-left: 3px solid var(--verde, #36e452);
        padding-left: 1em;
        margin: 1em 0;
        font-style: italic;
    }

    #notion-content .notion-block.bulleted-list,
    #notion-content .notion-block.numbered-list {
        margin: 0.5em 0;
        padding-left: 1.5em;
    }

    #notion-content .notion-block.bulleted-list-item,
    #notion-content .notion-block.numbered-list-item {
        margin: 0.2em 0;
    }

    #notion-content .notion-block.todo-item {
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 0.3em 0;
    }

    #notion-content .notion-block.code-block {
        background: #f5f5f5;
        padding: 1em;
        border-radius: 4px;
        overflow-x: auto;
        margin: 1em 0;
    }

    #notion-content .notion-block.code-block code {
        font-family: monospace;
        font-size: 14px;
    }

    #notion-content .notion-block.divider {
        border: none;
        border-top: 1px solid #e0e0e0;
        margin: 1.5em 0;
    }

    #notion-content .notion-block.image {
        margin: 1em 0;
    }

    #notion-content .notion-block.image img {
        max-width: 100%;
        display: block;
    }

    #notion-content .notion-block.image figcaption {
        font-size: 0.85em;
        color: #666;
        margin-top: 0.5em;
        text-align: center;
    }

    #notion-content .notion-block.bookmark {
        margin: 0.5em 0;
    }

    #notion-content .notion-block.bookmark a {
        word-break: break-all;
    }

    #notion-content .notion-block.embed {
        margin: 1em 0;
    }

    #notion-content .notion-block.child-page {
        margin: 0.5em 0;
    }

    #notion-content .child-page-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        color: inherit;
    }

    #notion-content h1,
    #notion-content h2,
    #notion-content h3 {
        margin: 0.6em 0 0.3em;
    }

    /* ── GranBoton style for heading_2 links ── */
    #notion-content .gran-boton-wrap {
        margin: 0.8em 0 0.4em;
    }

    #notion-content .gran-boton {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    #notion-content .gran-boton .verde {
        padding: 18px;
        width: 100%;
        background-color: var(--verde, #36e452);
        display: flex;
        align-items: center;
    }

    #notion-content .gran-boton .verde p {
        font-family: TitleFont, serif;
        font-size: 23px;
        margin: 0;
        flex: 1;
    }

    #notion-content .gran-boton .material-symbols-outlined {
        margin-left: 15px;
        flex-shrink: 0;
    }
</style>
