---
import Default from "../layouts/Default.astro";
import HClick from "../components/HClick.astro";

type Project = {
    pageId?: string;
    destino?: string;
    name: string;
};

function getEnlace(project: Project): string {
    if (project.pageId) {
        return `/id/${project.pageId}`;
    }
    if (project.destino) {
        return project.destino;
    }
    return "";
}

const getTarget = (enlace: string): "_self" | "_blank" => {
    if (!enlace) return "_self";
    try {
        const url = new URL(enlace);
        if (url.hostname.endsWith("aedm.org.es")) {
            return "_self";
        }
        return "_blank";
    } catch {
        return "_self";
    }
};

function isInternal(enlace: string): boolean {
    if (!enlace) return true;
    if (!/^https?:\/\//i.test(enlace)) return true;
    try {
        const url = new URL(enlace);
        return url.hostname.endsWith("aedm.org.es");
    } catch {
        return true;
    }
}

let projects: Project[] = [];
let error: string | null = null;

try {
    const response = await fetch("https://api.aedm.org.es/PROYECTOS_DB.json");
    if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
    }
    projects = await response.json();
} catch (err) {
    console.error("Error fetching projects:", err);
    error = "No se pudieron cargar los proyectos.";
}
---

<Default title="Proyectos">
    {error && <p>{error}</p>}

    {
        projects.map((project) => {
            const enlace = getEnlace(project);
            return (
                <HClick
                    texto={project.name}
                    {enlace}
                    icono="arrow_forward"
                    target={getTarget(enlace)}
                />
            );
        })
    }
</Default>
