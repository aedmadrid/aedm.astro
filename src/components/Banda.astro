---
const { texto, url } = Astro.props;

interface Props {
    texto: string;
    url: string;
}

const copies = 6;
const items = Array.from({ length: copies });
---

<div class="banda">
    <div class="track">
        <a href={url}>
            {items.map(() => <span>{texto}</span>)}
        </a>
    </div>
</div>

<style>
    .banda {
        background-color: var(--verde);
        position: fixed;
        overflow: hidden;
        left: 0;
        right: 0;
        top: 80px;
        height: 30px;
        z-index: 100000;
        display: flex;
        align-items: center;
    }
    .track {
        display: inline-block;
        white-space: nowrap;
        animation: scroll 20s linear infinite;
    }
    a {
        text-decoration: none;
        color: inherit;
        cursor: pointer;
        display: flex;
        width: max-content;
    }
    span {
        padding-right: 2rem;
    }
    @keyframes scroll {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(calc(-100% / 6));
        }
    }
</style>
