---
import "../styles/main.css";
---

<header>
    <a href="/" style="padding: 0;margin: 0;"><img id="aedm" src="/src/images/aedm.svg" /></a>
    <span id="moBotn" class="material-symbols-outlined">menu</span>
    <div class="botones">
        <a href="/">Inicio</a>
        <a href="/reclama">Expone-Solicita</a>
        <a href="/actividades">Actividades</a>
        <a href="/proyectos">Proyectos</a>
        <a href="/app">APP</a>
        <a href="/contacto">Contacto</a>
    </div>
</header>

<style>
    #moBotn {
        display: none;
    }
    #aedm {
        height: 40px;
        cursor: pointer;
    }
    header {
        gap: 24px;
        height: 80px;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-around;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        margin: 0;
        padding: 0;
        user-select: none;
        background-color: transparent;
        background: linear-gradient(
            rgba(255, 255, 255, 2),
            rgba(255, 255, 255, 0.8),
            rgba(255, 255, 255, 0.6),
            rgba(255, 255, 255, 0)
        );

        z-index: 10000;
    }
    .botones {
        gap: 24px;
        display: flex;
        flex-direction: row;
    }

    .botones a {
        color: var(--black);
        text-decoration: none;
    }

    @media screen and (max-width: 700px) {
        .botones {
            display: flex;
            position: fixed;
            left: 0;
            right: 0;
            bottom: 0;
            top: 0;
            flex-direction: column;
            background-color: var(--verde);
            padding: 10px;
            padding-top: 80px;
            margin: 0;
            gap: 15px;
            text-align: end;
            justify-content: center;
            font-size: 30px;
            z-index: -1;
            color: var(--negro);
            transition: all 0.8s;
            transform: translateY(-100%);
            a {
                margin: 0;
                padding: 0
                width: auto;
                border-bottom: 2px dotted var(--negro);
            }
        }
        #moBotn {
            display: block;
            transition: transform 0.1s cubic-bezier(0.075, 0.82, 0.165, 1);
        }
        .rotated {
            transform: rotate(90deg);
        }
        header {
            justify-content: space-between;
            * {
                margin: 25px;
            }
        }
    }
</style>

<script>
const moBotn = document.getElementById("moBotn");

    function despMenu() {
        const botones = document.querySelector(".botones") as HTMLElement;
        if (botones) {
            const currentTransform = botones.style.transform;
            botones.style.transform =
                currentTransform === "translateY(0px)" ? "translateY(-100%)" : "translateY(0px)";
            moBotn!.innerHTML = moBotn?.innerHTML === "close" ? "menu" : "close";
            moBotn!.classList.toggle("rotated", moBotn!.innerHTML === "close");
        }
    }

    if (moBotn) {
        moBotn.addEventListener("click", despMenu);
    }
</script>
