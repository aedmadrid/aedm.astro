---
import GranBoton from "./GranBoton.astro";
import HClick from "./HClick.astro";
import Boton from "./Boton.astro";

interface RichTextAnnotations {
    bold?: boolean;
    italic?: boolean;
    underline?: boolean;
    strikethrough?: boolean;
    code?: boolean;
    color?: string;
}

interface RichTextItem {
    plain_text: string;
    href?: string | null;
    annotations?: RichTextAnnotations;
}

interface NotionBlock {
    id: string;
    type:
        | "paragraph"
        | "heading_1"
        | "heading_2"
        | "heading_3"
        | "bulleted_list_item"
        | "to_do"
        | "quote"
        | "bookmark"
        | "code"
        | "divider"
        | "embed"
        | "child_page"
        | "image";
    rich_text?: RichTextItem[];
    checked?: boolean;
    url?: string;
    title?: string;
    caption?: RichTextItem[];
    language?: string;
}

interface Props {
    blocks: NotionBlock[];
}

const { blocks } = Astro.props;

const COLOR_HEX: Record<string, string> = {
    gray: "#9B9A97",
    brown: "#7B4B25",
    orange: "#D9730D",
    yellow: "#DFAB01",
    green: "#0F7B6C",
    blue: "#0B6E99",
    purple: "#6940A5",
    pink: "#AD1A72",
    red: "#E03E3E",
};

const COLOR_BG_HEX: Record<string, string> = {
    gray: "#F1F1EF",
    brown: "#F4E6D4",
    orange: "#FEEEDA",
    yellow: "#FEF3C0",
    green: "#DDEDEA",
    blue: "#DDEBF1",
    purple: "#EAE4F2",
    pink: "#FBE4F0",
    red: "#FDEBEC",
};

function getColorStyle(color?: string): string {
    if (!color || color === "default") return "";
    if (color.endsWith("_background")) {
        const base = color.replace("_background", "");
        const bg = COLOR_BG_HEX[base] ?? COLOR_BG_HEX.gray;
        const fg = COLOR_HEX[base] ?? "#202020";
        return `background-color:${bg};color:${fg};`;
    }
    return `color:${COLOR_HEX[color] ?? color};`;
}

function richTextToHtml(items: RichTextItem[] = []): string {
    if (!items.length) return "&nbsp;";
    return items
        .map((item) => {
            const styles: string[] = [];
            if (item.annotations?.bold) styles.push("font-weight:600");
            if (item.annotations?.italic) styles.push("font-style:italic");
            const textDec: string[] = [];
            if (item.annotations?.underline) textDec.push("underline");
            if (item.annotations?.strikethrough) textDec.push("line-through");
            if (textDec.length)
                styles.push(`text-decoration:${textDec.join(" ")}`);
            const colorStyle = getColorStyle(item.annotations?.color);
            if (colorStyle) styles.push(colorStyle);

            const styleAttr = styles.length
                ? ` style="${styles.join(";")}"`
                : "";
            const content = item.plain_text || "\u00A0";
            const escaped = content
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;");

            if (item.href) {
                if (item.href.startsWith("/")) {
                    return `<a href="${item.href}"${styleAttr}>${escaped}</a>`;
                }
                return `<a href="${item.href}"${styleAttr} target="_blank" rel="noreferrer">${escaped}</a>`;
            }
            return `<span${styleAttr}>${escaped}</span>`;
        })
        .join("");
}

function getPlainText(items: RichTextItem[] = []): string {
    return items.map((i) => i.plain_text).join("");
}

// Group consecutive bulleted_list_item blocks into lists
type SingleGroup = { type: "single"; block: NotionBlock };
type ListGroup = { type: "list"; blocks: NotionBlock[] };
type BlockGroup = SingleGroup | ListGroup;

const groups: BlockGroup[] = [];
let i = 0;
while (i < blocks.length) {
    const block = blocks[i];
    if (block.type === "bulleted_list_item") {
        const items: NotionBlock[] = [];
        while (i < blocks.length && blocks[i].type === "bulleted_list_item") {
            items.push(blocks[i]);
            i++;
        }
        groups.push({ type: "list", blocks: items });
    } else {
        groups.push({ type: "single", block });
        i++;
    }
}
---

{blocks.length === 0 && <p>La página no contiene contenido.</p>}

{
    groups.map((group) => {
        if (group.type === "list") {
            return (
                <ul class="notion-block bulleted-list">
                    {group.blocks.map((item) => (
                        <li
                            class="notion-block bulleted-list-item"
                            set:html={richTextToHtml(item.rich_text)}
                        />
                    ))}
                </ul>
            );
        }

        const block = group.block;

        if (block.type === "paragraph") {
            return (
                <p
                    class="notion-block paragraph"
                    set:html={richTextToHtml(block.rich_text)}
                />
            );
        }

        if (block.type === "heading_1") {
            return (
                <h1
                    class="notion-block heading-1"
                    set:html={richTextToHtml(block.rich_text)}
                />
            );
        }

        if (block.type === "heading_2") {
            const rt = block.rich_text ?? [];
            if (rt.length === 1 && rt[0].href) {
                return (
                    <div class="notion-block heading-2">
                        <GranBoton
                            texto={rt[0].plain_text || rt[0].href || ""}
                            url={rt[0].href || "#"}
                            icono="arrow_outward"
                            orden={0}
                        />
                    </div>
                );
            }
            return (
                <h2
                    class="notion-block heading-2"
                    set:html={richTextToHtml(block.rich_text)}
                />
            );
        }

        if (block.type === "heading_3") {
            return (
                <h3
                    class="notion-block heading-3"
                    set:html={richTextToHtml(block.rich_text)}
                />
            );
        }

        if (block.type === "to_do") {
            return (
                <label class="notion-block todo-item">
                    <input type="checkbox" checked={!!block.checked} disabled />
                    <span set:html={richTextToHtml(block.rich_text)} />
                </label>
            );
        }

        if (block.type === "quote") {
            return (
                <blockquote
                    class="notion-block quote"
                    set:html={richTextToHtml(block.rich_text)}
                />
            );
        }

        if (block.type === "bookmark") {
            return (
                <div class="notion-block bookmark">
                    <Boton texto={block.url ?? ""} url={block.url ?? "#"} />
                </div>
            );
        }

        if (block.type === "code") {
            return (
                <pre class="notion-block code-block">
                    <code data-language={block.language}>
                        {getPlainText(block.rich_text)}
                    </code>
                </pre>
            );
        }

        if (block.type === "divider") {
            return <hr class="notion-block divider" />;
        }

        if (block.type === "embed") {
            return (
                <div class="notion-block embed">
                    <iframe
                        src={block.url}
                        title={`embed-${block.id}`}
                        loading="lazy"
                        allowfullscreen
                        style="width:100%;min-height:200px;border:0;"
                    />
                </div>
            );
        }

        if (block.type === "child_page") {
            return (
                <div class="notion-block child-page">
                    <HClick
                        texto={block.title || ""}
                        enlace={`/id/${block.id}`}
                        icono="arrow_forward"
                    />
                </div>
            );
        }

        if (block.type === "image") {
            return (
                <figure class="notion-block image">
                    <img
                        src={block.url}
                        alt={getPlainText(block.caption)}
                        style="max-width:100%;"
                    />
                    {block.caption && block.caption.length > 0 && (
                        <figcaption set:html={richTextToHtml(block.caption)} />
                    )}
                </figure>
            );
        }

        return null;
    })
}

<style>
    :global(.notion-block.paragraph) {
        margin: 0.25em 0;
    }

    :global(.notion-block.heading-1) {
        margin: 1em 0 0.5em;
    }

    :global(.notion-block.heading-2) {
        margin: 0.8em 0 0.4em;
    }

    :global(.notion-block.heading-3) {
        margin: 0.6em 0 0.3em;
    }

    :global(.notion-block.quote) {
        border-left: 3px solid var(--verde, #36e452);
        padding-left: 1em;
        margin: 1em 0;
        font-style: italic;
    }

    :global(.notion-block.bulleted-list) {
        margin: 0.5em 0;
        padding-left: 1.5em;
    }

    :global(.notion-block.bulleted-list-item) {
        margin: 0.2em 0;
    }

    :global(.notion-block.todo-item) {
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 0.3em 0;
    }

    :global(.notion-block.code-block) {
        background: #f5f5f5;
        padding: 1em;
        border-radius: 4px;
        overflow-x: auto;
        margin: 1em 0;
    }

    :global(.notion-block.code-block code) {
        font-family: monospace;
        font-size: 14px;
    }

    :global(.notion-block.divider) {
        border: none;
        border-top: 1px solid #e0e0e0;
        margin: 1.5em 0;
    }

    :global(.notion-block.embed) {
        margin: 1em 0;
    }

    :global(.notion-block.image) {
        margin: 1em 0;
    }

    :global(.notion-block.image figcaption) {
        font-size: 0.85em;
        color: #666;
        margin-top: 0.5em;
        text-align: center;
    }

    :global(.notion-block.bookmark) {
        margin: 0.5em 0;
    }

    :global(.notion-block.child-page) {
        margin: 0.5em 0;
    }
</style>
