---
const { texto, enlace, icono } = Astro.props;
import "../styles/main.css";

interface Props {
    texto: string;
    enlace?: string;
    icono: string;
}

const normalizedLink = enlace?.trim() || "";
const isDeviceLink = /^(mailto:|tel:|sms:|geo:)/i.test(normalizedLink);
const isExternalLink = /^https?:\/\//i.test(normalizedLink);

let target = "_self";
let rel = "";
if (isExternalLink) {
    target = "_blank";
    rel = "noopener noreferrer";
}

const isInteractive = !!normalizedLink;
const headingClass = isInteractive ? "hclick hclick--interactive" : "hclick";
---

{
    isInteractive ? (
        <a
            href={normalizedLink}
            target={isDeviceLink ? undefined : target}
            rel={rel || undefined}
            class={headingClass}
        >
            <span class="hclick__text">{texto}</span>
            <span
                class="material-symbols-outlined hclick__icon"
                aria-hidden="true"
            >
                {icono}
            </span>
        </a>
    ) : (
        <h3 class="hclick">
            <span class="hclick__text">{texto}</span>
            <span
                class="material-symbols-outlined hclick__icon"
                aria-hidden="true"
            >
                {icono}
            </span>
        </h3>
    )
}

<style>
    .hclick {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0;
        margin: 20px 0 10px;
        width: 100%;
        text-decoration: none;
        color: inherit;
        gap: 10px;
        box-sizing: border-box;
        border-bottom: 2px solid var(--verde, #36e452);
        font-size: 1.6em;
        font-weight: 400;
        font-family: inherit;
        scroll-margin-top: 130px;
    }

    .hclick--interactive {
        cursor: pointer;
        transition: opacity 0.2s ease;
    }

    .hclick--interactive:hover {
        opacity: 0.7;
    }

    .hclick--interactive:focus-visible {
        outline: 2px solid var(--verde, #36e452);
        outline-offset: 4px;
    }

    .hclick__text {
        font-family: inherit;
        font-size: inherit;
        margin: 0;
    }

    .hclick__icon {
        font-size: 24px;
        flex-shrink: 0;
    }
</style>
